# Oracle Cloud single-VM deployment template for docker compose
# Copy this to .env on the server and replace the placeholder values.

MYSQL_DATABASE=vcollab
MYSQL_USER=vcollab
MYSQL_PASSWORD=replace-with-a-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=80

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# Use your public VM IP until you attach a domain.
# When you add a domain, replace both values with https://your-domain.com
CORS_ALLOWED_ORIGINS=http://YOUR_PUBLIC_IP
MEDIA_BASE_URL=http://YOUR_PUBLIC_IP/uploads

DB_MAX_POOL_SIZE=15
DB_MIN_IDLE=5
