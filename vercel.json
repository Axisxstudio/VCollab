{
  "version": 2,
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!api|_next|assets|favicon.ico|logo.png|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
